# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# For local dev: postgresql://postgres:postgres@localhost:5432/voyage
# For Neon (production): get from https://console.neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/voyage?sslmode=require"

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Random string for signing session tokens.
# Generate with: openssl rand -base64 48
SESSION_SECRET="change-me-to-a-random-string-of-at-least-32-characters"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Optional: Email (Resend) ─────────────────────────────────────────────────
# For booking confirmation emails. Get from https://resend.com
# RESEND_API_KEY="re_..."
# EMAIL_FROM="noreply@yourdomain.com"

# ─── Optional: Error monitoring (Sentry) ──────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN="https://..."
# SENTRY_AUTH_TOKEN="..."
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="voyage"
